# Copy to `.env` and fill in. `.env` is git-ignored.

# Hugging Face token — OPTIONAL for Qwen2.5 (it is not gated). Only needed if you want
# to push your fine-tuned model to the Hub. Create one at
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Weights & Biases — for experiment tracking dashboards (loss curves, sweeps).
# Get it from https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=clintrial-lm

# Optional: only needed if you run the LLM-as-judge evaluation.
ANTHROPIC_API_KEY=
